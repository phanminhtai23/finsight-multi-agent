# Google OAuth Web client ID (from Google Cloud Console → Credentials → OAuth client ID).
# Must equal the backend's GOOGLE_OAUTH_CLIENT_ID. When empty, the Google button is hidden.
# Copy this file to .env and fill in the value, then restart `npm run dev`.
VITE_GOOGLE_CLIENT_ID=

# Backend API base URL. Leave empty for local dev (Vite proxies /api to localhost:8000).
# For production (Vercel), set to your deployed backend, e.g. https://api.example.com/api/v1
VITE_API_BASE_URL=
