# ---- App ----
ENVIRONMENT=dev
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

# ---- Datastores ----
# Default Postgres account, created when the postgres container first starts.
# If you change these, also update the two DSNs below to match.
POSTGRES_USER=finsight
POSTGRES_PASSWORD=finsight
POSTGRES_DB=finsight
# Async DSN for application tables (asyncpg)
DATABASE_URL=postgresql+asyncpg://finsight:finsight@postgres:5432/finsight
# Sync DSN for LangGraph PostgresSaver/PostgresStore (psycopg)
CHECKPOINT_DATABASE_URL=postgresql://finsight:finsight@postgres:5432/finsight
REDIS_URL=redis://redis:6379/0

# ---- LLM / embeddings ----
LLM_PROVIDER=google
GOOGLE_API_KEY=
LLM_MODEL=gemini-3.1-flash-lite-preview
EMBEDDING_MODEL=models/gemini-embedding-2
EMBEDDING_DIM=3072


# ---- Observability (LangSmith) ----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finsight
LANGSMITH_TRACING=false

# ---- File storage (Cloudinary) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Qdrant API (for agentic decision making) ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=finsight_chunks
# ---- MCP tool server ----
MCP_SERVER_URL=http://mcp:8001/mcp

# ---- Auth / security ----
JWT_SECRET=change-me-in-prod-please
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14
FRONTEND_URL=http://localhost:5173

# ---- Storage quota (per user, in MB) ----
STORAGE_QUOTA_MB=100

# ---- Google OAuth (optional — login with Google) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Email / SMTP (optional — verification emails; dev returns the token if unset) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=phanminhtai23@gmail.com
