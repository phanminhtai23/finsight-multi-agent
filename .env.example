# ---- App ----
ENVIRONMENT=dev
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

# ---- Datastores ----
# Async DSN for application tables (asyncpg)
DATABASE_URL=postgresql+asyncpg://finsight:finsight@postgres:5432/finsight
# Sync DSN for LangGraph PostgresSaver/PostgresStore (psycopg)
CHECKPOINT_DATABASE_URL=postgresql://finsight:finsight@postgres:5432/finsight
REDIS_URL=redis://redis:6379/0

# ---- LLM / embeddings (Google Gemini free tier — get key at https://aistudio.google.com/apikey) ----
LLM_PROVIDER=google
GOOGLE_API_KEY=
LLM_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIM=768

# ---- Observability (LangSmith) ----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finsight
LANGSMITH_TRACING=false

# ---- File storage (Cloudinary) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
